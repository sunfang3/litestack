<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>liteboard</title>
    <link rel="stylesheet" href="/assets/liteboard.css">
    <script src="/assets/liteboard.js" defer></script>
  </head>
  <body>
    <header class="lb-header" role="banner">
      <h1>
        <span class="lb-logo"><span class="lb-logo-half">lite</span>board</span>
        <span class="lb-logo" style="font-weight:normal;font-size:1rem"> — the <span class="lb-logo-half">lite</span>metric dashboard</span>
      </h1>
    </header>

    <div class="lb-shell">
      <nav class="lb-nav" aria-label="Topics">
        <ul>
          <li>
            <a href="<%= index_url %>" <%= 'aria-current="page"' unless @topic %>>Home</a>
          </li>
          <% Array(@topics).each do |topic| %>
            <li>
              <a href="<%= topic_url(topic[0]) %>" <%= 'aria-current="page"' if @topic == topic[0] %>><%= h(topic[0]) %></a>
            </li>
          <% end %>
        </ul>
      </nav>

      <main class="lb-main" id="main" role="main">
        <div class="lb-controls">
          <label for="res-select">Showing data for the last
            <select id="res-select" name="res" onchange="window.location = locationWithParam('res', this.value)">
              <% mapping = {"hour" => "60 minutes", "day" => "24 hours", "week" => "7 days", "year" => "52 weeks"} %>
              <% ["hour", "day", "week", "year"].each do |res| %>
                <option value="<%= res %>" <%= "selected" if res == @res %>><%= mapping[res] %></option>
              <% end %>
            </select>
          </label>
        </div>

        <noscript>
          <p class="noscript-note">JavaScript is disabled. Tables and metrics below remain fully readable.</p>
        </noscript>

        <%= yield %>
      </main>
    </div>

    <footer class="lb-footer" role="contentinfo">
      <span>Litestack Liteboard</span>
    </footer>
  </body>
</html>
