<section aria-labelledby="litejob-heading"><h2 id="litejob-heading">Litejob</h2>
<% if @empty_state %><div class="lb-empty" role="status"><p><strong>No Litejob metrics yet.</strong></p></div><% end %>
  <div class = "row">

    <div class = "col">
      <div class="card">
        <div class="card-header">
          Size
        </div>
        <div class="card-body">
          <h1><%=format(round(@size))%> MB</h1>
        </div>
      </div>
    </div>

    <div class = "col">
      <div class="card">
        <div class="card-header">
          Active queues
        </div>
        <div class="card-body">
          <h1><%=format(@queues.length)%></h1>
        </div>
      </div>
    </div>

    <div class = "col">
      <div class="card">
        <div class="card-header">
          Outstanding jobs
        </div>
        <div class="card-body">
          <h1><%=format(@jobs)%></h1>
        </div>
      </div>
    </div>

  </div>
  
  <div class = "row">
  &nbsp;<br/>
  </div>

  
  <div class="row">
  
    <div class = "col">
      <div class="card">
        <div class="card-header">
          Processed jobs
        </div>
        <div class="card-body">
          <h1><%=format(@processed_count)%> jobs</h1>
        </div>
      </div>
    </div>
    
    <div class = "col">
      <div class="card">
        <div class="card-header">
          Total processing time
        </div>
        <div class="card-body">
          <h1><%=format(@processing_time)%> sec</h1>
        </div>
      </div>
    </div>

    <div class = "col">
      <div class="card">
        <div class="card-header">
          Average processing time per job
        </div>
        <div class="card-body">
          <h1><%= @processed_count.to_i.zero? ? 0 : (@processing_time.to_f / @processed_count).truncate(4) %> sec</h1>
        </div>
      </div>
    </div>

  </div>

  <div class = "row">
  &nbsp;<br/>
  </div>

  <div class="row">
  
    <div class = "col">
      <div class="card">
        <div class="card-header">
          Processed jobs by queue
        </div>
        <div class="card-body">
          <span class="hidden inlinepie">
            <%=[["name", "value"]] + @processed_count_by_queue.to_a%>
          </span>
        </div>
      </div>
    </div>
    
    <div class = "col">
      <div class="card">
        <div class="card-header">
          Job processing time by queue
        </div>
        <div class="card-body">
          <span class="hidden inlinepie">
            <%=[["name", "value"]] + @processing_time_by_queue.to_a%>
          </span>
        </div>
      </div>
    </div>

  </div>

  <div class = "row">
  &nbsp;<br/>
  </div>

  <div class="row">
  
    <div class = "col">
      <div class="card">
        <div class="card-header">
          Processed jobs by queue over time
        </div>
        <div class="card-body">
          <span class="hidden inlinestackedcolumn">
            <%=@processed_count_over_time_by_queues.to_a%>
          </span>
        </div>
      </div>
    </div>
    
    <div class = "col">
      <div class="card">
        <div class="card-header">
          Job processing time by queue over time
        </div>
        <div class="card-body">
          <span class="hidden inlinestackedcolumn">
            <%=@processing_time_over_time_by_queues.to_a%>
          </span>
        </div>
      </div>
    </div>

  </div>

  <div class = "row">
  &nbsp;<br/>
  </div>

  <div class="row">
    <div class="col">
      <div class="card" id="lifecycle-card"
           data-lifecycle-url="/topics/Litejob/lifecycle.json"
           data-lifecycle-poll="5000">
        <div class="card-header">
          Job lifecycle stream
          <span class="lb-muted" id="lifecycle-status">
            <% if @lifecycle_feed && @lifecycle_feed[:enabled] %>
              live · <%= h(@lifecycle_feed[:topic]) %>
            <% else %>
              inactive
            <% end %>
          </span>
        </div>
        <div class="card-body">
          <% if @lifecycle_feed.nil? || !@lifecycle_feed[:enabled] %>
            <div class="lb-empty" role="status">
              <p><strong>No lifecycle stream.</strong></p>
              <p class="lb-muted">
                Enable with <code>lifecycle_stream: true</code> on Litejobqueue
                (requires the <code>honker</code> gem and a file-backed queue path).
                <% if @lifecycle_feed && @lifecycle_feed[:reason] %>
                  <br/>Reason: <%= h(@lifecycle_feed[:reason]) %>
                <% end %>
                <% if @lifecycle_feed && @lifecycle_feed[:path] %>
                  <br/>Looking at: <code><%= h(@lifecycle_feed[:path]) %></code>
                <% end %>
              </p>
            </div>
          <% else %>
            <p class="lb-muted">
              Recent events from Honker stream
              <code><%= h(@lifecycle_feed[:topic]) %></code>
              on <code><%= h(@lifecycle_feed[:path]) %></code>.
              Auto-refreshes every 5s when JavaScript is available.
            </p>
            <div class="lb-table-wrap">
              <table class="lb-table" id="lifecycle-table">
                <thead>
                  <tr>
                    <th scope="col">Time (UTC)</th>
                    <th scope="col">Event</th>
                    <th scope="col">Job</th>
                    <th scope="col">Class</th>
                    <th scope="col">Queue</th>
                    <th scope="col">Detail</th>
                  </tr>
                </thead>
                <tbody id="lifecycle-tbody">
                  <% Array(@lifecycle_feed[:events]).reverse_each do |ev| %>
                    <tr>
                      <td><%= h(format_lifecycle_time(ev[:at])) %></td>
                      <td><code><%= h(ev[:event]) %></code></td>
                      <td><code><%= h(ev[:job_id]) %></code></td>
                      <td><%= h(ev[:klass]) %></td>
                      <td><%= h(ev[:queue]) %></td>
                      <td class="lb-muted"><%= h(ev[:error] || (ev[:delay] ? "delay=#{ev[:delay]}" : "")) %></td>
                    </tr>
                  <% end %>
                  <% if Array(@lifecycle_feed[:events]).empty? %>
                    <tr><td colspan="6" class="lb-muted">Stream is empty — enqueue a job to see events.</td></tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

</section>
